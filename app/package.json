{
  "name": "footlight-app",
  "version": "0.8.1",
  "description": "Footlight desktop app — a HandBrake-style GUI for cutting 16:9 video into 1080x1920 (9:16) vertical clips. Wraps ffmpeg.",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "author": "Trevor Baker",
  "repository": {
    "type": "git",
    "url": "https://github.com/tjbaker/footlight"
  },
  "bugs": {
    "url": "https://github.com/tjbaker/footlight/issues"
  },
  "homepage": "https://github.com/tjbaker/footlight",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "dev:server": "node dev-server/server.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "format": "prettier --write src/**/*.ts test/**/*.ts dev-server/**/*.mjs",
    "format:check": "prettier --check src/**/*.ts test/**/*.ts dev-server/**/*.mjs",
    "verify": "npm run format:check && npm test && npm run build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "prettier": "3.8.4",
    "typescript": "^5.5.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=26"
  }
}
