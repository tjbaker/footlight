{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in *.ts|*.mjs) cd \"$CLAUDE_PROJECT_DIR\" && npx prettier --write \"$f\" >/dev/null 2>&1 || true ;; esac"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npx tsc --noEmit)",
      "Bash(npm run build)",
      "Bash(npx vitest run *)",
      "Bash(npm test)",
      "Bash(npm run verify)",
      "Bash(npm run lint)",
      "Bash(npm run format:check)",
      "Bash(ffprobe *)",
      "Bash(circle services search *)",
      "Bash(circle services inspect *)",
      "Bash(circle wallet status)",
      "Bash(circle wallet balance)",
      "Bash(circle wallet list)",
      "mcp__claude_ai_Slack__slack_read_channel",
      "Bash(git fetch *)",
      "Bash(git checkout main)",
      "Bash(git checkout -b *)",
      "Bash(git switch *)",
      "Bash(git pull --ff-only)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push -u origin *)",
      "Bash(gh pr create *)"
    ]
  }
}
