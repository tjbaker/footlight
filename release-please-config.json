{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "node",
      "package-name": "footlight",
      "extra-files": [
        { "type": "json", "path": "app/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "app/src-tauri/tauri.conf.json", "jsonpath": "$.version" },
        { "type": "toml", "path": "app/src-tauri/Cargo.toml", "jsonpath": "$.package.version" },
        { "type": "toml", "path": "app/src-tauri/Cargo.lock", "jsonpath": "$.package[?(@.name=='footlight')].version" }
      ]
    }
  },
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance" },
    { "type": "refactor", "section": "Refactors" },
    { "type": "i18n", "section": "Internationalization" },
    { "type": "docs", "section": "Documentation" },
    { "type": "build", "section": "Build System" },
    { "type": "ci", "section": "CI", "hidden": true },
    { "type": "test", "section": "Tests", "hidden": true },
    { "type": "chore", "section": "Chores", "hidden": true }
  ]
}
